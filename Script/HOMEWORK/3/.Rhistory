# Importiamo il file CSV con encoding compatibile
df <- read.csv("UNLifeExpectancy.csv", fileEncoding = "latin1")
# Visualizziamo le prime righe
head(df)
# Vediamo la struttura: tipi di variabili e presenza di NA
str(df)
# Statistiche descrittive generali
summary(df)
# Contiamo i NA per ogni colonna
colSums(is.na(df))
# Selezioniamo solo le colonne numeriche con pochi NA
# Scegliamo: LIFEEXP, ILLITERATE, POP, FERTILITY, PRIVATEHEALTH,
# HEALTHEXPEND, PHYSICIAN, GDP
dati <- df %>%
select(COUNTRY, LIFEEXP, ILLITERATE, POP, FERTILITY,
PRIVATEHEALTH, HEALTHEXPEND, PHYSICIAN, GDP)
# Rimuoviamo le righe con NA
dati_clean <- na.omit(dati)
# Rimuoviamo anche la colonna COUNTRY (solo per il clustering)
dati_cluster <- dati_clean %>% select(-COUNTRY)
# Standardizziamo le variabili (media 0, deviazione standard 1)
dati_scaled <- scale(dati_cluster)
# Visualizziamo le prime righe normalizzate
head(dati_scaled)
# Calcolo del metodo Elbow usando fviz_nbclust
set.seed(123)  # per risultati ripetibili
fviz_nbclust(dati_scaled, kmeans, method = "wss") +
labs(title = "Metodo del gomito per scegliere il numero di cluster",
x = "Numero di cluster (k)",
y = "Somma dei quadrati intra-cluster (WSS)")
# Calcolo del metodo Elbow usando fviz_nbclust
set.seed(123)  # per risultati ripetibili
fviz_nbclust(dati_scaled, kmeans, method = "wss") +
labs(title = "Metodo del gomito per scegliere il numero di cluster",
x = "Numero di cluster (k)",
y = "Somma dei quadrati intra-cluster (WSS)")
# Applichiamo k-means con 5 cluster
set.seed(123)  # per ripetibilità
kmeans_res <- kmeans(dati_scaled, centers = 5, nstart = 25)
# Aggiungiamo il numero di cluster al dataset pulito
dati_clean$cluster <- as.factor(kmeans_res$cluster)
# Visualizziamo le prime righe con il cluster assegnato
head(dati_clean)
# Centroidi: valori medi (standardizzati) per ogni cluster
kmeans_res$centers
# Visualizzazione con PCA + colore per cluster
fviz_cluster(kmeans_res, data = dati_scaled,
geom = "point",
ellipse.type = "convex",
palette = "jco",
ggtheme = theme_minimal(),
main = "Visualizzazione dei cluster (k = 5)")
# Calcoliamo silhouette plot per i 5 cluster trovati
silhouette_k5 <- silhouette(kmeans_res$cluster, dist(dati_scaled))
# Visualizziamo il grafico silhouette
fviz_silhouette(silhouette_k5) +
labs(title = "Qualità dei cluster (k = 5) - Silhouette plot")
# Applichiamo k-means con 4 cluster
set.seed(123)  # per ripetibilità
kmeans_res <- kmeans(dati_scaled, centers = 4, nstart = 25)
# Aggiungiamo il numero di cluster al dataset pulito
dati_clean$cluster <- as.factor(kmeans_res$cluster)
# Visualizziamo le prime righe con il cluster assegnato
head(dati_clean)
# Centroidi: valori medi (standardizzati) per ogni cluster
kmeans_res$centers
# Visualizzazione con PCA + colore per cluster
fviz_cluster(kmeans_res, data = dati_scaled,
geom = "point",
ellipse.type = "convex",
palette = "jco",
ggtheme = theme_minimal(),
main = "Visualizzazione dei cluster (k = 4)")
# Calcoliamo silhouette plot per i 4 cluster trovati
silhouette_k4 <- silhouette(kmeans_res$cluster, dist(dati_scaled))
# Visualizziamo il grafico silhouette
fviz_silhouette(silhouette_k4) +
labs(title = "Qualità dei cluster (k = 4) - Silhouette plot")
# Applichiamo k-means con 4 cluster
set.seed(123)  # per ripetibilità
kmeans_res <- kmeans(dati_scaled, centers = 3, nstart = 25)
# Aggiungiamo il numero di cluster al dataset pulito
dati_clean$cluster <- as.factor(kmeans_res$cluster)
# Visualizziamo le prime righe con il cluster assegnato
head(dati_clean)
# Centroidi: valori medi (standardizzati) per ogni cluster
kmeans_res$centers
# Visualizzazione con PCA + colore per cluster
fviz_cluster(kmeans_res, data = dati_scaled,
geom = "point",
ellipse.type = "convex",
palette = "jco",
ggtheme = theme_minimal(),
main = "Visualizzazione dei cluster (k = 4)")
# Calcoliamo silhouette plot per i 4 cluster trovati
silhouette_k4 <- silhouette(kmeans_res$cluster, dist(dati_scaled))
# Visualizziamo il grafico silhouette
fviz_silhouette(silhouette_k4) +
labs(title = "Qualità dei cluster (k = 4) - Silhouette plot")
# Applichiamo k-means con 4 cluster
set.seed(123)  # per ripetibilità
kmeans_res <- kmeans(dati_scaled, centers = 3, nstart = 25)
# Aggiungiamo il numero di cluster al dataset pulito
dati_clean$cluster <- as.factor(kmeans_res$cluster)
# Visualizziamo le prime righe con il cluster assegnato
head(dati_clean)
# Centroidi: valori medi (standardizzati) per ogni cluster
kmeans_res$centers
# Visualizzazione con PCA + colore per cluster
fviz_cluster(kmeans_res, data = dati_scaled,
geom = "point",
ellipse.type = "convex",
palette = "jco",
ggtheme = theme_minimal(),
main = "Visualizzazione dei cluster (k = 3)")
# Calcoliamo silhouette plot per i 3 cluster trovati
silhouette_k3 <- silhouette(kmeans_res$cluster, dist(dati_scaled))
# Visualizziamo il grafico silhouette
fviz_silhouette(silhouette_k3) +
labs(title = "Qualità dei cluster (k = 3) - Silhouette plot")
# Aggiungiamo il cluster finale (k = 3) ai dati originali
dati_clean$cluster_k3 <- as.factor(kmeans(dati_scaled, centers = 3, nstart = 25)$cluster)
# Calcoliamo le medie delle variabili per ciascun cluster
cluster_summary <- dati_clean %>%
group_by(cluster_k3) %>%
summarise(across(LIFEEXP:GDP, mean, na.rm = TRUE))
# Visualizziamo la tabella
print(cluster_summary)
# OPTIONAL: Mostriamo anche quanti paesi ci sono per ciascun cluster
table(dati_clean$cluster_k3)
