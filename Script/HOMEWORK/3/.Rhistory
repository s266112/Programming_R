# Caricamento dei dati
earnings <- read.csv("earnings.csv")
# Visualizzazione delle prime righe
head(earnings)
# Struttura delle variabili
str(earnings)
# Statistiche descrittive generali
summary(earnings)
# Rimuoviamo i casi con valori mancanti o earn <= 0
earnings_clean <- earnings %>%
filter(!is.na(earn), earn > 0)
# Convertiamo le variabili categoriche in factor
earnings_clean$sex <- as.factor(earnings_clean$sex)
# Caricamento dati
earnings <- read.csv("earnings.csv")
# Prime righe del dataset
head(earnings)
# Controllo struttura
str(earnings)
# Valori mancanti per colonna
colSums(is.na(earnings))
# Statistiche descrittive
summary(earnings)
# Copia del dataset originale
df <- earnings
# Rimuoviamo osservazioni con NA nelle colonne chiave
df_clean <- df %>%
select(earn, age, height, male, education, smokenow, exercise) %>%
na.omit()
# Controlliamo quanti casi sono rimasti
nrow(df_clean)
# Convertiamo variabili categoriche in fattori
df_clean$male <- as.factor(df_clean$male)
df_clean$education <- as.factor(df_clean$education)
df_clean$smokenow <- as.factor(df_clean$smokenow)
df_clean$exercise <- as.factor(df_clean$exercise)
# Verifica finale
str(df_clean)
# Costruiamo il modello completo con tutte le variabili
model_full <- lm(earn ~ age + height + male + education + smokenow + exercise, data = df_clean)
# Riepilogo del modello
summary(model_full)
# Visualizziamo i residui
par(mfrow = c(2, 2))
plot(model_full)
# Distribuzione dei residui
hist(residuals(model_full),
main = "Distribuzione dei residui",
col = "lightgreen")
# Verifica della normalità con QQ plot
qqnorm(residuals(model_full))
qqline(residuals(model_full), col = "red")
# Costruiamo un nuovo modello con log(earn)
model_log <- lm(log(earn) ~ age + height + male + education + smokenow + exercise, data = df_clean)
# Riepilogo del nuovo modello
summary(model_log)
# Diagnostica dei residui dopo la trasformazione
par(mfrow = c(2, 2))
plot(model_log)
# Istogramma dei nuovi residui
hist(residuals(model_log),
col = "lightblue", main = "Residui del modello log(earn)")
# Q-Q plot dei nuovi residui
qqnorm(residuals(model_log))
qqline(residuals(model_log), col = "red")
# Visualizziamo i residui
par(mfrow = c(2, 2))
plot(model_full)
# Distribuzione dei residui
hist(residuals(model_full),
main = "Distribuzione dei residui",
col = "lightgreen")
# Verifica della normalità con QQ plot
qqnorm(residuals(model_full))
qqline(residuals(model_full), col = "red")
# Costruiamo un nuovo modello con log(earn)
model_log <- lm(log(earn) ~ age + height + male + education + smokenow + exercise, data = df_clean)
# Riepilogo del nuovo modello
summary(model_log)
# Diagnostica dei residui dopo la trasformazione
par(mfrow = c(2, 2))
plot(model_log)
# Istogramma dei nuovi residui
hist(residuals(model_log),
col = "lightblue", main = "Residui del modello log(earn)")
# Q-Q plot dei nuovi residui
qqnorm(residuals(model_log))
qqline(residuals(model_log), col = "red")
# Rimuoviamo eventuali osservazioni con earn <= 0 o NA
df_log <- df_clean %>% filter(!is.na(earn), earn > 0)
# Modello con log(earn) come variabile risposta
model_log <- lm(log(earn) ~ age + height + male + education + smokenow + exercise, data = df_log)
# Riepilogo del nuovo modello
summary(model_log)
# Diagnostica grafica
par(mfrow = c(2, 2))
plot(model_log)
# Istogramma dei nuovi residui
hist(residuals(model_log),
col = "lightblue", main = "Residui del modello log(earn)")
# Q-Q plot dei nuovi residui
qqnorm(residuals(model_log))
qqline(residuals(model_log), col = "red")
# Applichiamo la selezione automatica (backward di default)
model_pars <- step(model_log, direction = "both", trace = FALSE)
# Riepilogo del modello finale selezionato
summary(model_pars)
